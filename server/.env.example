GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
QUEUE_CONCURRENCY=2
QUEUE_INTERVAL=1000
# Set to "production" to serve the built React app from Express
NODE_ENV=development
# Allowed cross-origin for CORS.
# In development defaults to http://localhost:5173 when unset.
# In production defaults to same-origin (cross-origin blocked) when unset.
# Set this if your client is hosted on a different origin than the server.
CLIENT_ORIGIN=http://localhost:5173
