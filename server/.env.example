GEMINI_API_KEY=your_gemini_api_key_here
PORT=3001
# Set to 'production' in production environments
NODE_ENV=development
# Comma-separated list of allowed CORS origins (required in production when frontend is on a separate domain)
ALLOWED_ORIGIN=https://your-production-domain.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
QUEUE_CONCURRENCY=2
QUEUE_INTERVAL=1000
